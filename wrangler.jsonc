{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "titan",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "TITAN_DB",
      "database_name": "titan",
      "migrations_dir": "db/migrations"
    }
  ]
}
